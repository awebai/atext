# PostgreSQL database used by atext
ATEXT_DATABASE_URL=postgresql://localhost/atext

# AWID registry used to resolve team public keys and certificate revocations
ATEXT_AWID_REGISTRY_URL=https://api.awid.ai

# Cache public AWID team facts for 10 minutes
ATEXT_AUTH_CACHE_TTL_SECONDS=600

# Reject signed requests more than 5 minutes from server time
ATEXT_TIMESTAMP_SKEW_SECONDS=300
